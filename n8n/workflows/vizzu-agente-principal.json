      }
    },
    {
      "id": "payment-context",
      "name": "Preparar Resposta de Pagamento",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1910, 160],
      "parameters": { "jsCode": "const ctx=$('Dados do Plano').item.json; const link=$json.init_point||$json.sandbox_init_point; const response=`Ótimo! 🎉 Aqui está seu link de pagamento para o plano ${ctx.plan.name}:\\n\\n💳 ${link}\\n\\n✅ Pix: R$ ${ctx.plan.pix.toLocaleString('pt-BR')} (10% OFF)\\n💳 Cartão: até ${ctx.plan.installments}x sem juros\\n\\nAssim que o pagamento for confirmado, nossa equipe de onboarding entra em contato!`; return [{json:{...ctx,response,patch:{...ctx.patch,estagio:'aguardando_pagamento',plano_escolhido:ctx.plano,valor_plano:ctx.plan.value,link_pagamento:link}}}];" }
    },
    {
      "id": "patch-session",
