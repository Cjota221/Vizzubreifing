      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1470, 160],
      "parameters": { "jsCode": "const plans={basico:{name:'VIZZU Básico',value:790,pix:711,installments:3},intermediario:{name:'VIZZU Intermediário',value:1490,pix:1341,installments:6},completo:{name:'VIZZU Completo',value:2490,pix:2241,installments:9}}; return [{json:{...$json,plan:plans[$json.plano]||plans.intermediario}}];" }
    },
    {
      "id": "mp-preference",
      "name": "Mercado Pago - Criar Preferência",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1690, 160],
      "parameters": {
        "method": "POST", "url": "https://api.mercadopago.com/checkout/preferences",
        "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "Authorization", "value": "={{ 'Bearer ' + $env.MP_ACCESS_TOKEN }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "contentType": "raw", "rawContentType": "application/json",
